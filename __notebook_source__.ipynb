# CELL 21: ZIP EVERYTHING + SPLIT INTO 100MB PARTS
# =============================================================================
print(f"\n{'='*60}\n📦 ZIPPING & SPLITTING RESULTS\n{'='*60}")

zip_path = '/kaggle/working/everything.zip'
print("📦 Zipping everything...")
with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
    for root, dirs, files in os.walk('/kaggle/working'):
        for file in files:
            if file.endswith('.zip') or file.endswith('.part') or file.startswith('.'):
                continue
            file_path = os.path.join(root, file)
            arcname = os.path.relpath(file_path, '/kaggle/working')
            zipf.write(file_path, arcname)

size_mb = os.path.getsize(zip_path) / (1024 * 1024)
print(f"✅ Zip created: {size_mb:.0f} MB")

print("\n✂️ Splitting into 100MB parts...")
chunk_size = 100 * 1024 * 1024
total_parts = math.ceil(os.path.getsize(zip_path) / chunk_size)
with open(zip_path, 'rb') as f:
    for i in range(total_parts):
        chunk = f.read(chunk_size)
        part_path = f'/kaggle/working/part_{i}.zip.part'
        with open(part_path, 'wb') as chunk_file:
            chunk_file.write(chunk)
        part_mb = len(chunk) / (1024 * 1024)
        print(f"   ✅ part_{i}.zip.part ({part_mb:.0f} MB)")

os.remove(zip_path)
print(f"\n📦 Split into {total_parts} parts of ≤100MB each")
print(f"📥 Download each part_X.zip.part from the Output tab")
parts = '+'.join([f'part_{i}.zip.part' for i in range(total_parts)])
print(f"\n🔧 To rejoin locally, open CMD in your download folder and run:")
print(f"   copy /b {parts} everything.zip")

