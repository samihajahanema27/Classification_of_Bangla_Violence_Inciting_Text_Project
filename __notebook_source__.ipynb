        f.write(f"\n--- {rr['combo']} ---\n")
        f.write(classification_report(test_labels, rr['predictions'], target_names=label_names) + "\n")
    f.write("\n" + "="*60 + "\nSTACKING META-LEARNER\n" + "="*60 + "\n")
    f.write(classification_report(test_labels, stacking_preds, target_names=label_names) + "\n")

