def weighted_ensemble_predict(probs_list, f1s_list):
    n = len(probs_list[0]); final = []
    for i in range(n):
        ws = np.zeros(3)
        for c in range(3):
            tw = sum(f[c] for f in f1s_list) + 1e-10
            ws[c] = sum(p[i][c] * f[c] for p, f in zip(probs_list, f1s_list)) / tw
        final.append(np.argmax(ws))
    return np.array(final)

