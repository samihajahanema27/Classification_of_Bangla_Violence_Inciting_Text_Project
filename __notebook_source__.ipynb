model_names_list = list(model_probs.keys())
from itertools import combinations

routing_all_results = []
for combo in combinations(model_names_list, 3):
    combo_name = " + ".join(combo)
    c_test = [model_probs[m][0] for m in combo]
    def route_predict(probs_list, names, threshold=0.7):
        n = len(probs_list[0]); final = []; stats = {nm: 0 for nm in names}; stats['Average'] = 0
        for i in range(n):
            confs = [(np.max(p[i]), p[i], nm) for p, nm in zip(probs_list, names)]
            confs.sort(key=lambda x: x[0], reverse=True)
            if confs[0][0] >= threshold:
                final.append(np.argmax(confs[0][1])); stats[confs[0][2]] += 1
            else:
                avg = sum(p[i] for p in probs_list) / len(probs_list)
                final.append(np.argmax(avg)); stats['Average'] += 1
        return np.array(final), stats
    rpreds, rstats = route_predict(c_test, list(combo))
    ra = accuracy_score(test_labels, rpreds)
    rp, rr, rf, _ = precision_recall_fscore_support(test_labels, rpreds, average='macro')
    print(f"\n   📌 {combo_name}")
    print(f"      Routing: {rstats}")
    print(f"      Acc:{ra:.4f} P:{rp:.4f} R:{rr:.4f} F1:{rf:.4f}")
    routing_all_results.append({
        'model': f'CR: {combo_name}', 'accuracy': round(ra,4),
        'precision': round(rp,4), 'recall': round(rr,4), 'f1_score': round(rf,4),
