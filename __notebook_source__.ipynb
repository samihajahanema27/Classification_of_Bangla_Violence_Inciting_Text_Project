def get_bert_probabilities(model_path, texts, model_name="Model"):
    print(f"   📥 Extracting {model_name} probabilities...")
    tokenizer = AutoTokenizer.from_pretrained(model_path)
    model = AutoModelForSequenceClassification.from_pretrained(model_path).to(device); model.eval()
    all_probs = []
    with torch.no_grad():
        for i in range(0, len(texts), 64):
            bt = texts[i:i+64]
            inputs = tokenizer(bt, max_length=128, padding='max_length', truncation=True, return_tensors='pt').to(device)
            probs = F.softmax(model(**inputs).logits, dim=1).cpu().numpy()
            all_probs.extend(probs)
            if (i//64+1) % 10 == 0: print(f"      {min(i+64, len(texts))}/{len(texts)}")
    del model; torch.cuda.empty_cache()
    return np.array(all_probs)

def get_mt5_probabilities(model_path, texts):
    print(f"   📥 Extracting mT5 probabilities...")
    tokenizer = T5Tokenizer.from_pretrained(model_path)
    model = T5ForConditionalGeneration.from_pretrained(model_path).to(device); model.eval()
    labels = ['Non_Violence', 'Passive_Violence', 'Violence']
    all_probs = []
    with torch.no_grad():
        for i in range(0, len(texts), 32):
            for text in texts[i:i+32]:
                input_ids = tokenizer(f"classify: {text}", max_length=128, truncation=True, return_tensors='pt').input_ids.to(device)
                scores = []
                for label in labels:
                    lid = tokenizer(label, return_tensors='pt').input_ids.to(device)
                    scores.append(-model(input_ids=input_ids, labels=lid).loss.item())
                s = np.array(scores); e = np.exp(s - np.max(s)); all_probs.append(e / e.sum())
            if (i//32+1) % 10 == 0: print(f"      {min(i+32, len(texts))}/{len(texts)}")
    del model; torch.cuda.empty_cache()
    return np.array(all_probs)

def get_rule_transformer_probabilities(texts, scaler):
    print(f"   📥 Extracting Rule-Based Transformer probabilities...")
    feats = np.array([extract_rule_features(t) for t in texts])
    feats = scaler.transform(feats)
    model = RuleBasedTransformer().to(device)
    ckpt = torch.load(os.path.join(Config.MODEL_DIR, 'rule_transformer.pt'), weights_only=False)
    model.load_state_dict(ckpt['model']); model.eval()
    loader = DataLoader(torch.FloatTensor(feats), batch_size=128, shuffle=False)
    all_probs = []
    with torch.no_grad():
        for batch in loader:
            probs = F.softmax(model(batch.to(device)), dim=1).cpu().numpy()
            all_probs.extend(probs)
    return np.array(all_probs)

