# === CELL 4: LOAD DATA ===
def load_data():
    train_df = pd.read_csv(Config.TRAIN_FILE, encoding='utf-8-sig')
    val_df = pd.read_csv(Config.VAL_FILE, encoding='utf-8-sig')
    test_df = pd.read_csv(Config.TEST_FILE, encoding='utf-8-sig')
    print(f"📊 Train: {len(train_df)} | Val: {len(val_df)} | Test: {len(test_df)}")
    for cls, count in train_df['Emotion'].value_counts().items():
        print(f"   {cls}: {count} ({count/len(train_df)*100:.1f}%)")
    return train_df, val_df, test_df
train_df, val_df, test_df = load_data()

# === CELL 5: DATASET CLASSES ===
class ViolenceDataset(Dataset):
    def __init__(self, texts, labels, tokenizer, max_length=Config.MAX_LENGTH):
        self.texts, self.labels, self.tokenizer, self.max_length = texts, labels, tokenizer, max_length
    def __len__(self): return len(self.texts)
    def __getitem__(self, idx):
        enc = self.tokenizer(str(self.texts[idx]), max_length=self.max_length,
            padding='max_length', truncation=True, return_tensors='pt')
        return {'input_ids': enc['input_ids'].squeeze(), 'attention_mask': enc['attention_mask'].squeeze(),
                'label': torch.tensor(self.labels[idx], dtype=torch.long)}

class MT5Dataset(Dataset):
    def __init__(self, texts, labels, tokenizer, max_length=Config.MAX_LENGTH):
        self.texts, self.labels, self.tokenizer, self.max_length = texts, labels, tokenizer, max_length
    def __len__(self): return len(self.texts)
    def __getitem__(self, idx):
        source = self.tokenizer(f"classify: {self.texts[idx]}", max_length=self.max_length,
            padding='max_length', truncation=True, return_tensors='pt')
        target = self.tokenizer(str(self.labels[idx]), max_length=32,
            padding='max_length', truncation=True, return_tensors='pt')
        target_ids = target['input_ids'].squeeze()
        target_ids[target_ids == self.tokenizer.pad_token_id] = -100
        return {'input_ids': source['input_ids'].squeeze(),
                'attention_mask': source['attention_mask'].squeeze(), 'labels': target_ids}

class RuleFeatureDataset(Dataset):
    def __init__(self, features, labels):
        self.features = torch.FloatTensor(features)
        self.labels = torch.LongTensor(labels)
    def __len__(self): return len(self.labels)
    def __getitem__(self, idx):
        return {'features': self.features[idx], 'label': self.labels[idx]}

def create_dataloaders(train_df, val_df, test_df, tokenizer, batch_size, is_mt5=False):
    texts_train, texts_val, texts_test = train_df['Comments'].tolist(), val_df['Comments'].tolist(), test_df['Comments'].tolist()
    if is_mt5:
        ds = [MT5Dataset(t, l, tokenizer) for t, l in zip(
            [texts_train, texts_val, texts_test],
            [train_df['Emotion'].tolist(), val_df['Emotion'].tolist(), test_df['Emotion'].tolist()])]
    else:
        ds = [ViolenceDataset(t, [Config.LABEL2ID[l] for l in df['Emotion']], tokenizer) for t, df in zip(
            [texts_train, texts_val, texts_test], [train_df, val_df, test_df])]
    return (DataLoader(ds[0], batch_size=batch_size, shuffle=True),
            DataLoader(ds[1], batch_size=Config.VAL_BATCH_SIZE, shuffle=False),
            DataLoader(ds[2], batch_size=Config.VAL_BATCH_SIZE, shuffle=False))

# === CELL 6: RULE-BASED FEATURE EXTRACTOR ===
VIOLENCE_KEYWORDS = ['মারা','মারব','মারো','মেরে','পেটানো','পিটানো','পিটিয়ে','হত্যা','খুন','নিহত',
    'জবাই','কুপিয়ে','ধ্বংস','বিনাশ','পোড়াও','জ্বালাও','ভাঙচুর','আক্রমণ','হামলা','চড়াও',
    'গুলি','বোমা','শাস্তি','সাজা','ফাঁসি','প্রতিশোধ','গ্রেপ্তার','ধরা','আটক','গুম',
    'ধর্ষণ','নির্যাতন','অত্যাচার','বের করো','তাড়াও','বিতাড়িত','রক্ত','লাশ','মৃত্যু','মরুক']
PASSIVE_VIOLENCE_KEYWORDS = ['লজ্জা','অপমান','বেইজ্জত','অবমাননা','ঘৃণা','বিদ্বেষ','অবজ্ঞা','তুচ্ছ',
    'ভয়','আতঙ্ক','শঙ্কা','ভীতি','রাগ','ক্রোধ','গোস্সা','ক্ষোভ','কষ্ট','দুঃখ','যন্ত্রণা',
    'চোর','দুর্নীতি','ভ্রষ্টাচার','দালাল','নষ্ট','বাজে','নিকৃষ্ট','জঘন্য','ষড়যন্ত্র',
    'বিশ্বাসঘাতক','মুনাফিক','লুচ্চা','বদমাশ','হারামি','শয়তান','নালায়েক','বেয়াদব','বেশ্যা','মাগি']
THREAT_PATTERNS = [r'করে\s*ফেলব',r'দেখে\s*নিব',r'ছাড়ব\s*না',r'বুঝিয়ে\s*দিব',r'শিক্ষা\s*দিব',
    r'মজা\s*দেখাব',r'উচিত\s*শিক্ষা',r'রেহাই\s*নেই',r'পার\s*পাবে\s*না']
CALL_TO_ACTION_PATTERNS = [r'মারো',r'ধরো',r'পেটাও',r'বের\s*করো',r'তাড়াও',r'জ্বালাও',
    r'পোড়াও',r'ভাঙো',r'বয়কট',r'প্রতিবাদ\s*করো',r'রুখে\s*দাঁড়াও']

def extract_rule_features(text):
    text = str(text); words = text.split(); wc = max(len(words), 1)
    viol_kw = sum(1 for w in words for kw in VIOLENCE_KEYWORDS if kw in w)
    pass_kw = sum(1 for w in words for kw in PASSIVE_VIOLENCE_KEYWORDS if kw in w)
    profanity_words = ['শালা','শালি','বাল','চুদ','মাদার','হারামি','কুত্তা','শুয়োর']
    prof = sum(1 for w in words for p in profanity_words if p in w)
    exc = text.count('!'); qm = text.count('?'); tl = len(text)
    awl = np.mean([len(w) for w in words]) if words else 0
    sc = max(1, len(re.split(r'[।.!?]', text)))
    ht = int(any(re.search(p, text) for p in THREAT_PATTERNS))
    hca = int(any(re.search(p, text) for p in CALL_TO_ACTION_PATTERNS))
    eng = sum(1 for c in text if c.isascii() and c.isalpha()) / max(1, tl)
    return [viol_kw, pass_kw, prof, exc, eng, tl, wc, awl, qm, ht, hca, sc,
            viol_kw/wc, pass_kw/wc, int(prof>0)]
print("✅ Rule-based feature extractor ready (15 features)")

# === CELL 7: RULE-BASED TRANSFORMER MODEL ===
class RuleBasedTransformer(nn.Module):
    def __init__(self, input_dim=15, d_model=64, nhead=4, num_layers=2, num_classes=3):
        super().__init__()
        self.input_proj = nn.Sequential(nn.BatchNorm1d(input_dim), nn.Linear(input_dim, d_model), nn.ReLU())
        encoder_layer = nn.TransformerEncoderLayer(d_model=d_model, nhead=nhead, dim_feedforward=128,
            dropout=0.1, batch_first=True)
        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)
        self.classifier = nn.Sequential(nn.Dropout(0.2), nn.Linear(d_model, num_classes))
    def forward(self, x):
        x = self.input_proj(x).unsqueeze(1)
        x = self.transformer(x).squeeze(1)
        return self.classifier(x)

# === CELL 8: BERT-STYLE TRAINING FUNCTION ===
def train_bert_model(model_name, display_name, learning_rate, train_df, val_df, test_df):
    print(f"\n{'='*60}\n🚀 TRAINING: {display_name} ({model_name})\n{'='*60}")
    tokenizer = AutoTokenizer.from_pretrained(model_name)
    model = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=Config.NUM_LABELS,
        id2label=Config.ID2LABEL, label2id=Config.LABEL2ID).to(device)
    train_loader, val_loader, test_loader = create_dataloaders(train_df, val_df, test_df, tokenizer,
        batch_size=Config.TRAIN_BATCH_SIZE, is_mt5=False)
    optimizer = torch.optim.AdamW(model.parameters(), lr=learning_rate, weight_decay=Config.WEIGHT_DECAY)
    total_steps = len(train_loader) * Config.EPOCHS
    scheduler = get_linear_schedule_with_warmup(optimizer, int(total_steps*Config.WARMUP_RATIO), total_steps)
    criterion = nn.CrossEntropyLoss()
    best_val_f1, patience_counter = 0, 0
    history = {'train_loss': [], 'val_loss': [], 'val_f1': [], 'val_acc': []}
    for epoch in range(Config.EPOCHS):
        model.train(); total_loss = 0; start = time.time()
        for batch_idx, batch in enumerate(train_loader):
            ids, mask, labels = batch['input_ids'].to(device), batch['attention_mask'].to(device), batch['label'].to(device)
            loss = criterion(model(input_ids=ids, attention_mask=mask).logits, labels)
            optimizer.zero_grad(); loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0); optimizer.step(); scheduler.step()
            total_loss += loss.item()
            if (batch_idx+1) % 50 == 0: print(f"   E{epoch+1} B{batch_idx+1}/{len(train_loader)} Loss:{loss.item():.4f}")
        avg_tl = total_loss / len(train_loader)
        model.eval(); val_loss = 0; preds, lbls = [], []
        with torch.no_grad():
            for batch in val_loader:
                ids, mask, labels = batch['input_ids'].to(device), batch['attention_mask'].to(device), batch['label'].to(device)
                out = model(input_ids=ids, attention_mask=mask)
                val_loss += criterion(out.logits, labels).item()
                preds.extend(torch.argmax(out.logits, dim=1).cpu().numpy()); lbls.extend(labels.cpu().numpy())
        avg_vl = val_loss/len(val_loader); va = accuracy_score(lbls, preds)
        vp, vr, vf, _ = precision_recall_fscore_support(lbls, preds, average='macro')
        history['train_loss'].append(avg_tl); history['val_loss'].append(avg_vl)
        history['val_f1'].append(vf); history['val_acc'].append(va)
        print(f"   📊 E{epoch+1} ({time.time()-start:.0f}s) TL:{avg_tl:.4f} VL:{avg_vl:.4f} VA:{va:.4f} VF1:{vf:.4f}")
        if vf > best_val_f1:
            best_val_f1 = vf; patience_counter = 0
            sp = os.path.join(Config.MODEL_DIR, display_name.lower().replace(' ','_'))
            model.save_pretrained(sp); tokenizer.save_pretrained(sp); print(f"   💾 Saved (F1:{vf:.4f})")
        else:
            patience_counter += 1; print(f"   ⚠️ No improvement ({patience_counter}/{Config.EARLY_STOPPING_PATIENCE})")
        if patience_counter >= Config.EARLY_STOPPING_PATIENCE: print(f"   ⏹️ Early stop E{epoch+1}"); break
    sp = os.path.join(Config.MODEL_DIR, display_name.lower().replace(' ','_'))
    model = AutoModelForSequenceClassification.from_pretrained(sp).to(device); model.eval()
    preds, lbls = [], []
    with torch.no_grad():
        for batch in test_loader:
            ids, mask, labels = batch['input_ids'].to(device), batch['attention_mask'].to(device), batch['label'].to(device)
            preds.extend(torch.argmax(model(input_ids=ids, attention_mask=mask).logits, dim=1).cpu().numpy())
            lbls.extend(labels.cpu().numpy())
    ta = accuracy_score(lbls, preds); tp, tr, tf, _ = precision_recall_fscore_support(lbls, preds, average='macro')
    print(f"\n   ✅ {display_name} TEST: Acc:{ta:.4f} P:{tp:.4f} R:{tr:.4f} F1:{tf:.4f}")
    print(classification_report(lbls, preds, target_names=[Config.ID2LABEL[i] for i in range(3)]))
    results = {'model': display_name, 'accuracy': round(ta,4), 'precision': round(tp,4),
        'recall': round(tr,4), 'f1_score': round(tf,4), 'history': history,
        'predictions': preds, 'true_labels': lbls}
    with open(os.path.join(Config.OUTPUT_DIR, f"{display_name.lower().replace(' ','_')}_results.json"), 'w') as f:
        sr = {k:v for k,v in results.items() if k not in ['predictions','true_labels','history']}
        sr['history'] = {k:[round(x,4) for x in v] for k,v in history.items()}
        json.dump(sr, f, indent=2)
    del model; torch.cuda.empty_cache()
    return results

# === CELL 9: MT5 TRAINING FUNCTION ===
def train_mt5_model(train_df, val_df, test_df):
    display_name = "mT5"
    print(f"\n{'='*60}\n🚀 TRAINING: mT5 (Text-to-Text)\n{'='*60}")
    tokenizer = T5Tokenizer.from_pretrained(Config.MT5_MODEL)
    model = T5ForConditionalGeneration.from_pretrained(Config.MT5_MODEL).to(device)
    train_loader, val_loader, test_loader = create_dataloaders(train_df, val_df, test_df, tokenizer,
        batch_size=Config.MT5_BATCH_SIZE, is_mt5=True)
    optimizer = torch.optim.AdamW(model.parameters(), lr=Config.LEARNING_RATE_MT5, weight_decay=Config.WEIGHT_DECAY)
    total_steps = len(train_loader) * Config.EPOCHS
    scheduler = get_linear_schedule_with_warmup(optimizer, int(total_steps*Config.WARMUP_RATIO), total_steps)
    best_val_f1, patience_counter = 0, 0
    history = {'train_loss': [], 'val_loss': [], 'val_f1': [], 'val_acc': []}
    for epoch in range(Config.EPOCHS):
        model.train(); total_loss = 0; start = time.time()
        for batch_idx, batch in enumerate(train_loader):
            ids, mask, labels = batch['input_ids'].to(device), batch['attention_mask'].to(device), batch['labels'].to(device)
            loss = model(input_ids=ids, attention_mask=mask, labels=labels).loss
            optimizer.zero_grad(); loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0); optimizer.step(); scheduler.step()
            total_loss += loss.item()
            if (batch_idx+1) % 50 == 0: print(f"   E{epoch+1} B{batch_idx+1}/{len(train_loader)} Loss:{loss.item():.4f}")
        avg_tl = total_loss / len(train_loader)
        model.eval(); val_loss = 0; preds, lbls = [], []
        with torch.no_grad():
            for batch in val_loader:
                ids, mask, lb = batch['input_ids'].to(device), batch['attention_mask'].to(device), batch['labels'].to(device)
                val_loss += model(input_ids=ids, attention_mask=mask, labels=lb).loss.item()
                gen = model.generate(input_ids=ids, attention_mask=mask, max_new_tokens=32)
                dp = tokenizer.batch_decode(gen, skip_special_tokens=True)
                tl = lb.clone(); tl[tl==-100] = tokenizer.pad_token_id
                dl = tokenizer.batch_decode(tl, skip_special_tokens=True)
                for pt, lt in zip(dp, dl):
                    pid = Config.LABEL2ID.get(pt.strip(), -1); lid = Config.LABEL2ID.get(lt.strip(), -1)
                    if lid != -1: preds.append(pid if pid != -1 else 0); lbls.append(lid)
        avg_vl = val_loss/len(val_loader)
        va = accuracy_score(lbls, preds) if lbls else 0
        _,_,vf,_ = precision_recall_fscore_support(lbls, preds, average='macro', zero_division=0) if lbls else (0,0,0,0)
        history['train_loss'].append(avg_tl); history['val_loss'].append(avg_vl)
        history['val_f1'].append(vf); history['val_acc'].append(va)
        print(f"   📊 E{epoch+1} ({time.time()-start:.0f}s) TL:{avg_tl:.4f} VL:{avg_vl:.4f} VA:{va:.4f} VF1:{vf:.4f}")
        if vf > best_val_f1:
            best_val_f1 = vf; patience_counter = 0
            sp = os.path.join(Config.MODEL_DIR, 'mt5')
            model.save_pretrained(sp); tokenizer.save_pretrained(sp); print(f"   💾 Saved (F1:{vf:.4f})")
        else:
            patience_counter += 1; print(f"   ⚠️ No improvement ({patience_counter}/{Config.EARLY_STOPPING_PATIENCE})")
        if patience_counter >= Config.EARLY_STOPPING_PATIENCE: print(f"   ⏹️ Early stop E{epoch+1}"); break
    sp = os.path.join(Config.MODEL_DIR, 'mt5')
    model = T5ForConditionalGeneration.from_pretrained(sp).to(device); model.eval()
    preds, lbls = [], []
    with torch.no_grad():
        for batch in test_loader:
            ids, mask, lb = batch['input_ids'].to(device), batch['attention_mask'].to(device), batch['labels'].to(device)
            gen = model.generate(input_ids=ids, attention_mask=mask, max_new_tokens=32)
            dp = tokenizer.batch_decode(gen, skip_special_tokens=True)
            tl = lb.clone(); tl[tl==-100] = tokenizer.pad_token_id
            dl = tokenizer.batch_decode(tl, skip_special_tokens=True)
            for pt, lt in zip(dp, dl):
                pid = Config.LABEL2ID.get(pt.strip(), -1); lid = Config.LABEL2ID.get(lt.strip(), -1)
                if lid != -1: preds.append(pid if pid != -1 else 0); lbls.append(lid)
    ta = accuracy_score(lbls, preds); tp, tr, tf, _ = precision_recall_fscore_support(lbls, preds, average='macro', zero_division=0)
    print(f"\n   ✅ mT5 TEST: Acc:{ta:.4f} P:{tp:.4f} R:{tr:.4f} F1:{tf:.4f}")
    print(classification_report(lbls, preds, target_names=[Config.ID2LABEL[i] for i in range(3)], zero_division=0))
    results = {'model': display_name, 'accuracy': round(ta,4), 'precision': round(tp,4),
        'recall': round(tr,4), 'f1_score': round(tf,4), 'history': history,
        'predictions': preds, 'true_labels': lbls}
    with open(os.path.join(Config.OUTPUT_DIR, 'mt5_results.json'), 'w') as f:
        sr = {k:v for k,v in results.items() if k not in ['predictions','true_labels','history']}
        sr['history'] = {k:[round(x,4) for x in v] for k,v in history.items()}
        json.dump(sr, f, indent=2)
    del model; torch.cuda.empty_cache()
    return results

# === CELL 10: RULE-BASED TRANSFORMER TRAINING ===
def train_rule_transformer(train_df, val_df, test_df):
    print(f"\n{'='*60}\n🚀 TRAINING: Rule-Based Transformer\n{'='*60}")
    train_feats = np.array([extract_rule_features(t) for t in train_df['Comments']])
    val_feats = np.array([extract_rule_features(t) for t in val_df['Comments']])
    test_feats = np.array([extract_rule_features(t) for t in test_df['Comments']])
    train_labels = np.array([Config.LABEL2ID[l] for l in train_df['Emotion']])
    val_labels = np.array([Config.LABEL2ID[l] for l in val_df['Emotion']])
    test_labels = np.array([Config.LABEL2ID[l] for l in test_df['Emotion']])
    from sklearn.preprocessing import StandardScaler
    scaler = StandardScaler(); train_feats = scaler.fit_transform(train_feats)
    val_feats = scaler.transform(val_feats); test_feats = scaler.transform(test_feats)
    train_loader = DataLoader(RuleFeatureDataset(train_feats, train_labels), batch_size=64, shuffle=True)
    val_loader = DataLoader(RuleFeatureDataset(val_feats, val_labels), batch_size=128, shuffle=False)
    test_loader = DataLoader(RuleFeatureDataset(test_feats, test_labels), batch_size=128, shuffle=False)
    model = RuleBasedTransformer().to(device)
    optimizer = torch.optim.AdamW(model.parameters(), lr=Config.RULE_TRANSFORMER_LR, weight_decay=0.01)
    criterion = nn.CrossEntropyLoss()
    best_val_f1, patience = 0, 0
    history = {'train_loss': [], 'val_loss': [], 'val_f1': [], 'val_acc': []}
    for epoch in range(Config.RULE_TRANSFORMER_EPOCHS):
        model.train(); total_loss = 0
        for batch in train_loader:
            feats, labels = batch['features'].to(device), batch['label'].to(device)
            loss = criterion(model(feats), labels)
            optimizer.zero_grad(); loss.backward(); optimizer.step()
            total_loss += loss.item()
        avg_tl = total_loss / len(train_loader)
        model.eval(); val_loss = 0; preds, lbls = [], []
        with torch.no_grad():
            for batch in val_loader:
                feats, labels = batch['features'].to(device), batch['label'].to(device)
                out = model(feats); val_loss += criterion(out, labels).item()
                preds.extend(torch.argmax(out, dim=1).cpu().numpy()); lbls.extend(labels.cpu().numpy())
        avg_vl = val_loss/len(val_loader); va = accuracy_score(lbls, preds)
        _,_,vf,_ = precision_recall_fscore_support(lbls, preds, average='macro')
        history['train_loss'].append(avg_tl); history['val_loss'].append(avg_vl)
        history['val_f1'].append(vf); history['val_acc'].append(va)
        if (epoch+1) % 5 == 0: print(f"   E{epoch+1}/{Config.RULE_TRANSFORMER_EPOCHS} TL:{avg_tl:.4f} VL:{avg_vl:.4f} VA:{va:.4f} VF1:{vf:.4f}")
        if vf > best_val_f1:
            best_val_f1 = vf; patience = 0
            torch.save({'model': model.state_dict(), 'scaler_mean': scaler.mean_, 'scaler_scale': scaler.scale_},
                os.path.join(Config.MODEL_DIR, 'rule_transformer.pt'))
        else:
            patience += 1
            if patience >= 5: print(f"   ⏹️ Early stop E{epoch+1}"); break
    ckpt = torch.load(os.path.join(Config.MODEL_DIR, 'rule_transformer.pt'), weights_only=False)
    model.load_state_dict(ckpt['model']); model.eval()
    preds, lbls = [], []
    with torch.no_grad():
        for batch in test_loader:
            feats, labels = batch['features'].to(device), batch['label'].to(device)
            preds.extend(torch.argmax(model(feats), dim=1).cpu().numpy()); lbls.extend(labels.cpu().numpy())
    ta = accuracy_score(lbls, preds); tp, tr, tf, _ = precision_recall_fscore_support(lbls, preds, average='macro')
    print(f"\n   ✅ Rule-Based Transformer TEST: Acc:{ta:.4f} P:{tp:.4f} R:{tr:.4f} F1:{tf:.4f}")
    print(classification_report(lbls, preds, target_names=[Config.ID2LABEL[i] for i in range(3)]))
    results = {'model': 'Rule-Based Transformer', 'accuracy': round(ta,4), 'precision': round(tp,4),
        'recall': round(tr,4), 'f1_score': round(tf,4), 'history': history,
        'predictions': preds, 'true_labels': lbls}
    with open(os.path.join(Config.OUTPUT_DIR, 'rule_transformer_results.json'), 'w') as f:
        sr = {k:v for k,v in results.items() if k not in ['predictions','true_labels','history']}
        sr['history'] = {k:[round(x,4) for x in v] for k,v in history.items()}
        json.dump(sr, f, indent=2)
    return results, scaler

